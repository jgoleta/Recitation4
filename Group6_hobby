<!DOCTYPE html>
<html lang="en">

<head>
    <title>Grinding Gears</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            font-family: Century Gothic;
        }
        .topnav {
            overflow: hidden;
            background-color: #4f4f4f;
        }
        .topnav a {
            float: left;
            color: #f2f2f2;
            text-align: center;
            padding: 14px 16px;
            text-decoration: none;
            font-size: 17px;
        }
        .topnav a:hover {
            background-color: #ddd;
            color: black;
        }
        .topnav a.active {
            background-color: #04AA6D;
            color: white;
        }
        * {
            box-sizing: border-box;
        }
        body {
            font-family: Century Gothic;
        }
        header {
		background-image: url('https://i.ibb.co/4Z3qt5pk/r34.png'); 
    		background-repeat: no-repeat;
    		background-size: cover;
    		background-position: center; 
    		padding: 30px;
    		text-align: right;
    		font-size: 20px;
    		color: black;
        }
        nav {
            float: left;
            width: 35%;
            height: 810px;
            background: #fff0db;
            padding: 20px;
        }
        nav ul {
            list-style-type: none;
            padding: 0;
            color: #4f4f4f;
        }
        article {
            float: left;
            padding: 20px;
            width: 65%;
            background-color: white;
            height: 810px;
        }
        section::after {
            content: "";
            display: table;
            clear: both;
        }
        footer {
            background-color: #4f4f4f;
            padding: 20px;
            text-align: left;
            color: black;
        }

        img {
            border-radius: 50%;
        }
        @media (max-width: 600px) {
            nav,
            article {
                width: 100%;
                height: auto;
            }
        }
    </style>
</head>

<body>
    	<div class="topnav">
        	<a>Home</a>
        	<a>News</a>
        	<a>Contact</a>
        	<a>About</a>
    	</div>
	<header>
        	<h1 style="color:#eed9c4;">Iconic JDM Cars</h1>
    	</header>
</body>

</html>
